# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright e2e artifacts (generated, not source)
playwright-report/
test-results/
e2e/test-results.json

# playwright-mcp browser session artifacts (console logs, screenshots)
.playwright-mcp/

# per-user Obsidian editor state (workspace/graph layout); vault notes are tracked
vault/.obsidian/

# next.js
/.next/
/out/

# fumadocs-mdx generated output
/.source/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Auth E2E — Clerk test sessions (contain session tokens) and real-key env file
playwright/.clerk/
.env.e2e-auth

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Conductor / AI tooling (local only, re-provisioned automatically)
.agents/
.agent/
.opencode/
.claude/skills/
.codex/
.cursor/
.kiro/
skills/
skills-lock.json

# clerk configuration (can include secrets)
/.clerk/
.gstack/

# graphify knowledge-graph output (local navigation artifact, not a deliverable)
graphify-out/

# local runtime upload storage (property photos etc. written by the app, not repo content)
public/_storage/

# agent-loop: per-run pipeline state is transient, not committed
agent-loop/pipelines/*/runs/
!agent-loop/pipelines/*/runs/.gitkeep

# agent-loop: dashboard is a generated live view (regenerated from state)
agent-loop/dashboard.md

# agent-loop: orchestrator poll-loop heartbeat (transient liveness stamp)
agent-loop/orchestrator/.heartbeat

# agent-loop: improvement backlog is a generated snapshot (regenerated each tick)
agent-loop/memory/improvement-candidates.md
