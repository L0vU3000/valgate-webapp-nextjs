  Paid
  Overdue
  Pending
}

Enum terrain_type {
  Flat
  Rolling
  Hilly
  Mountainous
  Mixed
}

// ---------------------------------------------------------------------
// users (stub)
// ---------------------------------------------------------------------
Table users {
  id text [pk, note: 'Clerk subject (e.g. "demo-user")']
}

// ---------------------------------------------------------------------
// properties — central aggregate (38 fields)
// ---------------------------------------------------------------------
Table properties {
  id                    text [pk]
  user_id               text [not null, ref: > users.id]
  name                  text [not null]
  code                  text [not null]
  type                  property_type_choice [not null]
  status                property_status [not null]
  health                int  [not null, note: '0-100; Q5.K resolved: drop']
  lat                   double [not null]
  lng                   double [not null]
  is_archived           boolean
  // location
  address_line          text
  address_line2         text
  city                  text
  zip                   text
  country               text
  province              text [not null]
  // finance
  purchase_price        text [note: 'A2: should be numeric; Q5.P']
  purchase_date         bigint [note: 'ms epoch']
  current_market_value  numeric
  outstanding_mortgage  numeric
  monthly_payment       numeric
  interest_rate         numeric
  annual_property_tax   numeric
  tax_assessment_value  numeric
  annual_insurance      numeric
  ownership_status      text
  buy_numeric           numeric [not null, note: 'canonical purchase $']
  // media / specs
  photo_storage_ids     "text[]"
  document_storage_ids  "text[]"
  total_area            text [not null, note: 'A2: should be numeric']
  year_built            text [note: 'A2: should be int']
  bedrooms              text [note: 'A2: should be int']
  bathrooms             text [note: 'A2: should be int']
  parking_spaces        text [note: 'A2']
  storage_unit          text
  title                 property_title [not null]
  created_at            bigint [not null]
  updated_at            bigint [not null]

  Indexes {
    user_id              [name: 'idx_properties_user_id']
    (user_id, status)    [name: 'idx_properties_user_id_status']
  }

  Note: 'Central aggregate. 38 fields.  Hub of all property-scoped entities.'
}

// ---------------------------------------------------------------------
// tenants
// ---------------------------------------------------------------------
Table tenants {
  id          text [pk]
  user_id     text [not null, ref: > users.id]
  property_id text [not null, ref: > properties.id]
  name        text [not null]
  unit        text [not null]
  rent        numeric [not null]
  status      tenant_status [not null]
  email       text [note: 'A9: not validated as email']
  phone       text

  Indexes {
    user_id     [name: 'idx_tenants_user_id']
    property_id [name: 'idx_tenants_property_id']
  }
}

// ---------------------------------------------------------------------
// leases
// ---------------------------------------------------------------------
Table leases {
  id              text [pk]
  user_id         text [not null, ref: > users.id]
  property_id     text [not null, ref: > properties.id]
  tenant_id       text [ref: > tenants.id]
  unit            text [not null]
  stage           lease_stage [not null]
  start_date      bigint [not null]
  end_date        bigint [not null]
  monthly_rent    numeric [not null]
  term_months     int [not null]
  renewal_status  text

  Indexes {
    user_id            [name: 'idx_leases_user_id']
    property_id        [name: 'idx_leases_property_id']
    (user_id, stage)   [name: 'idx_leases_user_id_stage']
  }

  Note: 'A11 missing: deposit (numeric) and auto_pay (boolean) — UI shows "—" placeholders.'
}

// ---------------------------------------------------------------------
// payments
// ---------------------------------------------------------------------
Table payments {
  id          text [pk]
  user_id     text [not null, ref: > users.id]
  property_id text [not null, ref: > properties.id]
  lease_id    text [ref: > leases.id]
  tenant_id   text [ref: > tenants.id]
  date        bigint [not null, note: 'Q3.E: due-date vs invoice-date open']
  kind        payment_kind [not null]
  amount      numeric [not null]
  method      text [not null]
  status      payment_status [not null]

  Indexes {
    user_id              [name: 'idx_payments_user_id']
    property_id          [name: 'idx_payments_property_id']
    lease_id             [name: 'idx_payments_lease_id']
    (user_id, status)    [name: 'idx_payments_user_id_status']
  }
}

// ---------------------------------------------------------------------
// expenses
// ---------------------------------------------------------------------
Table expenses {
  id          text [pk]
  user_id     text [not null, ref: > users.id]
  property_id text [not null, ref: > properties.id]
  date        bigint [not null]
  category    expense_category [not null]
  amount      numeric [not null]
  note        text

  Indexes {
    user_id                [name: 'idx_expenses_user_id']
    property_id            [name: 'idx_expenses_property_id']
    (user_id, category)    [name: 'idx_expenses_user_id_category']
  }
}

// ---------------------------------------------------------------------
// folders (self-FK via parent_folder_id)
// ---------------------------------------------------------------------
Table folders {
  id                text [pk]
  user_id           text [not null, ref: > users.id]
  property_id       text [not null, ref: > properties.id]
  parent_folder_id  text [ref: > folders.id, note: 'self-FK; recursive folder tree']
  name              text [not null]
  created_at        bigint [not null]

  Indexes {
    user_id          [name: 'idx_folders_user_id']
    property_id      [name: 'idx_folders_property_id']
    parent_folder_id [name: 'idx_folders_parent_folder_id']
  }
}

// ---------------------------------------------------------------------
// documents
// ---------------------------------------------------------------------
Table documents {
  id                text [pk]
  user_id           text [not null, ref: > users.id]
  property_id       text [not null, ref: > properties.id]
  folder_id         text [ref: > folders.id]
  name              text [not null]
  kind              document_kind [not null]
  mime_type         text
  extension         text
  size_bytes        bigint
  storage_id        text [not null, note: 'Q5.C: → v.id("_storage") on Convex']
  thumb_storage_id  text
  category          text [note: 'A3 / Q5.R: should be closed enum']
  uploaded_by       text
  uploaded_at       bigint [not null]

  Indexes {
    user_id              [name: 'idx_documents_user_id']
    property_id          [name: 'idx_documents_property_id']
    folder_id            [name: 'idx_documents_folder_id']
    (user_id, category)  [name: 'idx_documents_user_id_category']
  }
}

// ---------------------------------------------------------------------
// inspections
// ---------------------------------------------------------------------
Table inspections {
  id          text [pk]
  user_id     text [not null, ref: > users.id]
  property_id text [not null, ref: > properties.id]
  date        text [not null, note: 'A1: should be bigint timestamp']
  type        text [not null]
  inspector   text [not null]
  status      text [not null, note: 'A3: should be enum (Passed/Failed/Pending)']
  issues      int  [not null]
  created_at  bigint [not null]
  updated_at  bigint [not null]

  Indexes {
    property_id [name: 'idx_inspections_property_id']
  }
}

