Project Valgate {
  database_type: 'PostgreSQL'
  Note: '''
    Property-management SaaS — 25 entities + users stub (26 tables).
    Anomalies tagged A1-A12 inline; full list in ref/07 §5.
  '''
}

// ---------------------------------------------------------------------
// ENUMs (19)
// ---------------------------------------------------------------------
Enum co_owner_role {
  Primary
  Minor
}

Enum distribution_method {
  "Pro-Rata by Share"
  "Equal Split"
  Custom
}

Enum document_kind {
  photo
  document
}

Enum estate_activity_kind {
  "successor.created"
  "successor.updated"
  "successor.deleted"
  "successor.assigned"
  "document.added"
  "document.removed"
  "estate.reviewed"
}

Enum expense_category {
  Maintenance
  Utilities
  Insurance
  Tax
  Management
  Other
}

Enum holding_type {
  "Tenancy in Common"
  "Joint Tenancy"
  "Sole Ownership"
  Trust
  LLC
  Other
}

Enum lease_stage {
  Approaching
  Offered
  Signed
  Declined
}

Enum maintenance_severity {
  Emergency
  Urgent
  Standard
}

Enum maintenance_status {
  Open
  InProgress
  Resolved
}

Enum notification_category {
  MAINTENANCE
  LEASING
  COMPLIANCE
  PAYMENT
  APPLICATIONS
}

Enum payment_kind {
  Rent
  Fee
  Deposit
  Refund
}

Enum payment_status {
  Paid
  Pending
  Failed
  Overdue
}

Enum property_status {
  Rented
  Vacant
  "For Sale"
  Sold
  Archived
  "Owner-Occupied"
}

Enum property_title {
  "Hard title"
  "Soft title"
  "—"
}

Enum property_type_choice {
  residential
  commercial
  "multi-unit"
  retail
  land
  industrial
  construction
  other
}

Enum successor_role {
  primary
  contingent
}

