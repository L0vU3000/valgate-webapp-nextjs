// ---------------------------------------------------------------------
Table certifications {
  id          text [pk]
  user_id     text [not null, ref: > users.id]
  property_id text [not null, ref: > properties.id]
  name        text [not null]
  status      text [not null, note: 'A3: should be enum (Valid/Expiring/Expired)']
  issued      text [not null, note: 'A1: should be bigint']
  expires     text [not null, note: 'A1: should be bigint']
  inspector   text [not null]
  created_at  bigint [not null]
  updated_at  bigint [not null]

  Indexes {
