# Map — required for property maps and location picker
NEXT_PUBLIC_MAPBOX_TOKEN=

# Demo login gate
SITE_PASSWORD=

# AI Chat — add your Anthropic key to enable Claude responses
# Get one at: console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: OpenAI fallback (only used if ANTHROPIC_API_KEY is empty)
OPENAI_API_KEY=

# Dev tools — show DEV shortcut buttons even in production/preview deployments
# Set to "true" in Vercel → Settings → Environment Variables (Preview scope)
# Leave blank to hide DEV buttons in all built environments
NEXT_PUBLIC_ENABLE_DEV_TOOLS=

# --- Backend (Neon/Drizzle/Clerk) — added in the backend migration ---
# Required. Neon connection string (use the DEV branch locally).
DATABASE_URL=
# Set to "true" to run without Clerk (requireCtx returns the ORG-0001 demo context). Refused in production.
DEMO_MODE=
# Local-dev only: allow writes while DEMO_MODE is on (against your own dev DB). Leave blank for a read-only demo.
DEMO_ALLOW_WRITES=
# Optional until Clerk Orgs are provisioned (flip DEMO_MODE=false then).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
# Optional S3 storage (document uploads).
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
# Optional Upstash rate-limiting (falls back to in-memory limiter when unset).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional Neon RLS (authenticated role) — post-merge.
DATABASE_AUTHENTICATED_URL=
