# Map — required for property maps and location picker
NEXT_PUBLIC_MAPBOX_TOKEN=

# AI Chat — add your OpenAI key to enable gpt-4o-mini responses + tool use
# Get one at: platform.openai.com
OPENAI_API_KEY=

# Dev tools — show DEV shortcut buttons even in production/preview deployments
# Set to "true" in Vercel → Settings → Environment Variables (Preview scope)
# Leave blank to hide DEV buttons in all built environments
NEXT_PUBLIC_ENABLE_DEV_TOOLS=

# --- Backend (Neon/Drizzle/Clerk) — added in the backend migration ---
# Required. Neon connection string (use the DEV branch locally).
DATABASE_URL=
# Set to "true" to run without Clerk (requireCtx returns the ORG-0001 demo context). Refused in production.
DEMO_MODE=
# Local-dev only: allow writes while DEMO_MODE is on (against your own dev DB). Leave blank for a read-only demo.
DEMO_ALLOW_WRITES=
# MCP server write switch (separate from the web app). Blank = the MCP surface is read-only.
# Set true so the local mcp:server can update/archive/delete/log.
MCP_ALLOW_WRITES=
# Stable HMAC secret for the delete-confirmation token. REQUIRED on Vercel (many serverless
# instances) so a delete preview and its confirm agree. Generate once: openssl rand -hex 32.
# Blank locally = per-boot random (fine for the single local stdio process).
MCP_CONFIRM_SECRET=
# Optional until Clerk Orgs are provisioned (flip DEMO_MODE=false then).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
# Point Clerk's middleware (auth.protect) at our custom pages, NOT the hosted Account Portal.
# Read at build time (NEXT_PUBLIC_*), so a redeploy is required after changing these.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
# Absolute app URL for server-generated links (Clerk invitation redirects). Local dev example:
# NEXT_PUBLIC_APP_URL=http://localhost:3001
# Optional S3 storage (document uploads).
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
# Optional Upstash rate-limiting (falls back to in-memory limiter when unset).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional Neon RLS (authenticated role) — post-merge.
DATABASE_AUTHENTICATED_URL=
# Resend — localized client invitation emails + bounce webhooks (Phase 3 onboarding).
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# Optional sender address (must be a verified Resend domain). Defaults to onboarding@resend.dev in dev.
RESEND_FROM_EMAIL=
# --- MCP server (/mcp) OAuth audience binding (Phase 3, M1) ---
# Comma-separated OAuth client ids allowed to call /mcp (e.g. a manually-registered ChatGPT app).
# When SET, /mcp rejects any other client. When UNSET, /mcp is "unbound" (any Clerk OAuth client) —
# see the flag below for how that is handled per environment.
MCP_ALLOWED_OAUTH_CLIENT_IDS=
# Production safety switch for the UNSET case above. In production, an unbound /mcp is REFUSED
# unless this is "true" — the conscious "run open for Dynamic Client Registration" opt-in (DCR
# client ids can't be allowlisted ahead of time). Dev/test are always permissive. Leave blank
# unless you intend an open, DCR-based /mcp in production.
MCP_ALLOW_ANY_OAUTH_CLIENT=
