{
  "name": "valgate-webapp-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -H 0.0.0.0 -p 3001",
    "dev:e2e": "DEMO_MODE=true DEMO_ALLOW_WRITES=true NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY= CLERK_SECRET_KEY=sk_test_placeholder SITE_PASSWORD= next dev --turbopack -H 0.0.0.0 -p 3001",
    "dev:tunnel": "npx --yes cloudflared@latest tunnel --url http://127.0.0.1:3001",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint app lib components",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "vitest run --config vitest.config.db.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auth": "PLAYWRIGHT_AUTH=1 playwright test --project auth-setup --project auth",
    "dev:e2e-auth": "node scripts/dev-e2e-auth.mjs",
    "seed": "node --conditions=react-server --import tsx scripts/seed.ts",
    "seed:reset": "node --conditions=react-server --import tsx scripts/seed.ts --reset",
    "regen-ai-ref": "node --import tsx scripts/regenerate-ai-data-ref.ts",
    "backfill:property-coords": "node --import tsx scripts/backfill-property-coords.ts",
    "seed:pro": "node --conditions=react-server --import tsx scripts/seed-pro.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:ping": "tsx --conditions=react-server --env-file=.env.local scripts/db-ping.ts",
    "db:assert": "tsx --conditions=react-server --env-file=.env.local scripts/schema-assert.ts",
    "seed:neon": "tsx --conditions=react-server --env-file=.env.local scripts/seed-neon.ts",
    "mcp:server": "tsx --conditions=react-server --env-file=.env.local mcp-server/index.ts",
    "mcp:inspect": "npx @modelcontextprotocol/inspector tsx --conditions=react-server --env-file=.env.local mcp-server/index.ts",
    "backfill:clients": "tsx --conditions=react-server --env-file=.env.local scripts/backfill-clients.ts",
    "promote": "git fetch origin main -q && if git merge-base --is-ancestor origin/main HEAD; then git push origin HEAD:main && echo '✓ Promoted current branch to main (fast-forward)'; else echo '✗ Refused: main has commits not on this branch. Bring origin/main into this branch first (git merge origin/main), then retry.' && exit 1; fi"
  },
